{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.eslint.tsbuildinfo",
    // tsconfig.app.json scopes `types` to the browser (vite/client only) since
    // that's what actually ships. Tests use Node built-ins (node:fs, node:path),
    // so ESLint's type-aware linting needs "node" too (matches tsconfig.test.json)
    // or those imports resolve to `any` and silently defeat unsafe-* rules.
    "types": ["vite/client", "node"]
  },
  "include": ["src"],
  "exclude": []
}
