{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "src/debug/main.tsx",
        "scripts/*.mjs",
        "src/routes/**/*.tsx"
      ],
      "project": ["src/**/*.{ts,tsx,css}", "scripts/**/*.mjs"],
      "ignoreIssues": {
        "src/components/ui/**": ["exports", "types"]
      }
    },
    "worker": {
      "project": ["src/**/*.ts"]
    }
  }
}
