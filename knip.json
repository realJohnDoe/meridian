{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "src/debug/main.tsx",
        "scripts/*.mjs",
        "src/routes/**/*.tsx",
        "src/components/ui/**/*.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx,css}", "scripts/**/*.mjs"]
    },
    "worker": {
      "project": ["src/**/*.ts"]
    }
  }
}
