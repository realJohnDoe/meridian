# Local installs are unfrozen so adding a dep without updating the lock doesn't fail.
# CI enforces the lockfile explicitly via `pnpm install --frozen-lockfile`.
frozen-lockfile=false

# Verify that every package's content matches the checksum stored in the lockfile.
# This catches corrupted or tampered packages before they run.
verify-store-integrity=true

# Resolve to the lowest version satisfying the range so updates are explicit and deliberate.
resolution-mode=lowest-direct

# Raise an error (not just a warning) when a peer-dep requirement can't be satisfied.
strict-peer-dependencies=false

# Do NOT hoist all packages to node_modules root — keeps the dep graph honest.
shamefully-hoist=false
