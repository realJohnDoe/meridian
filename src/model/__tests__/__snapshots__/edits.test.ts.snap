exports[`edit operations → serialized YAML > toggleDone on generated occurrence from the after_completion series targets series2 1`] = `
"---
defaults:
  done: false
title: Daily Check-in
tags:
  - work
instances:
  - date: 2026-04-01
    repeat:
      type: schedule
      freq: daily
      end:
        type: until
        date: 2026-04-09
    instances:
      - date: 2026-04-05
        done: true
  - date: 2026-04-10
    repeat:
      type: after_completion
      interval: 2 days
    instances:
      - date: 2026-04-10
        done: true
      - date: 2026-04-12
        done: true
---"
`;
