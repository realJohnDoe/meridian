      type: schedule
      freq: monthly
      interval: 1
      byweekday:
        - fr
      bysetpos: 1
  - date: 2026-07-10
    repeat:
      type: schedule
      freq: monthly
      interval: 1
      byweekday:
        - fr
      bysetpos: 2
---"
`;

